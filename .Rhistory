tinytex::tlmgr_install("babel-spanish")
rmarkdown::clean_site(preview = FALSE)
library(ggplot2)
# Datos estimados basados en estudios de endocrinología
datos_dhea <- data.frame(
edad = c(20, 30, 40, 50, 60, 70, 80),
niveles = c(100, 80, 55, 35, 20, 15, 10) # Porcentaje respecto al pico de juventud
)
ggplot(datos_dhea, aes(x = edad, y = niveles)) +
geom_line(color = "#2c3e50", size = 1.2) +
geom_point(color = "#e74c3c", size = 3) +
labs(
title = "Declive Fisiológico de DHEA/DHEA-S",
subtitle = "MetaPharmaceutical: Optimización Hormonal Bioidéntica",
x = "Edad (Años)",
y = "Nivel Sérico (% respecto al pico de los 20 años)",
caption = "Nota: El declive de la DHEA es uno de los biomarcadores más consistentes del envejecimiento."
) +
theme_minimal() +
scale_y_continuous(labels = function(x) paste0(x, "%"))
library(ggplot2)
# Datos estimados para mostrar la tendencia por sexo
datos_comparativos <- data.frame(
edad = rep(c(20, 30, 40, 50, 60, 70, 80), 2),
niveles = c(100, 82, 58, 38, 22, 16, 12,  # Hombres (Pico base)
90, 72, 48, 28, 15, 10, 8),   # Mujeres (Pico base ligeramente menor)
sexo = rep(c("Hombre", "Mujer"), each = 7)
)
ggplot(datos_comparativos, aes(x = edad, y = niveles, color = sexo, group = sexo)) +
geom_line(size = 1.3) +
geom_point(size = 3) +
scale_color_manual(values = c("Hombre" = "#2980b9", "Mujer" = "#e84393")) +
labs(
title = "Comparativa del Declive de DHEA/DHEA-S por Sexo",
subtitle = "MetaPharmaceutical: Dimorfismo sexual en el envejecimiento hormonal",
x = "Edad (Años)",
y = "Nivel Sérico (Escala relativa)",
color = "Sexo"
) +
theme_minimal() +
theme(legend.position = "bottom")
