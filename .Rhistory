library(ggplot2)
# Datos estimados en mcg/dL (Valores promedio referenciales)
datos_mcg <- data.frame(
edad = rep(c(20, 30, 40, 50, 60, 70, 80), 2),
niveles = c(450, 380, 280, 180, 120, 80, 50,  # Hombres (mcg/dL)
350, 280, 190, 110, 70, 40, 30),  # Mujeres (mcg/dL)
sexo = rep(c("Hombre", "Mujer"), each = 7)
)
ggplot(datos_mcg, aes(x = edad, y = niveles, color = sexo, group = sexo)) +
geom_line(linewidth = 1.3) +
geom_point(size = 3) +
scale_color_manual(values = c("Hombre" = "#2980b9", "Mujer" = "#e84393")) +
labs(
title = "Niveles Séricos de DHEA-S por Edad y Sexo",
subtitle = "Valores referenciales en microgramos (mcg/dL)",
x = "Edad (Años)",
y = "DHEA-S (mcg/dL)",
color = "Sexo",
caption = "MetaPharmaceutical: Optimización de Terapia Hormonal"
) +
theme_minimal() +
theme(legend.position = "bottom")
